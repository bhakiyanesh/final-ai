# FastAPI agent service
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# JWT verification
SUPABASE_JWT_AUDIENCE=authenticated
# SUPABASE_JWT_ISSUER=... # optional

# CORS: where the browser app is hosted
CORS_ORIGINS=http://localhost:3000

# Providers / rails
ENABLE_MOCK_RAILS=true
# RAIL_HTTP_QUOTE_URLS='{"stablecoin":"https://provider/quote","ach":"https://provider/quote","mobile_money":"https://provider/quote"}'
# RAIL_HTTP_EXECUTE_URLS='{"stablecoin":"https://provider/execute","ach":"https://provider/execute","mobile_money":"https://provider/execute"}'
# RAIL_HTTP_STATUS_URLS='{"stablecoin":"https://provider/status","ach":"https://provider/status","mobile_money":"https://provider/status"}'

# Optional LLM (for "Why this route?" explanation)
LLM_PRIMARY=openrouter
LLM_OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
LLM_OPENROUTER_MODEL=google/gemini-3.1-pro-preview
LLM_FALLBACK=ollama
LLM_OLLAMA_BASE_URL=http://localhost:11434/v1
# LLM_OLLAMA_MODEL=llama3

# Optional LangSmith
LANGSMITH_PROJECT=remittance-mvp

